# Core database settings. deploy/install.sh generates a random password.
POSTGRES_DB=manbaflow
POSTGRES_USER=manbaflow
POSTGRES_PASSWORD=replace-with-a-random-secret

# local starts the bundled PostgreSQL service; external uses the URL in the Secret file.
MAMBA_DATABASE_MODE=local
MAMBA_DATABASE_URL_SECRET_FILE=./deploy/secrets/database-url
# The installer writes the actual URL to the file above. Do not add MAMBA_DATABASE_URL here.

# Local bind and image. The public Caddy profile still keeps this port on loopback.
MAMBA_PORT=7777
MAMBA_IMAGE=manbaflow:local

# Set by: ./deploy/install.sh --hosted flow.example.com
MAMBA_DOMAIN=

# Append only the integrations you enable. Never commit the resulting .env.
# MAMBA_OIDC_ISSUER=https://id.example.com
# MAMBA_OIDC_CLIENT_ID=manbaflow
# MAMBA_OIDC_CLIENT_SECRET=replace-me
# MAMBA_OIDC_REDIRECT_URL=https://flow.example.com/auth/oidc/callback
# MAMBA_SCIM_BEARER_TOKEN=replace-with-at-least-32-characters
# MAMBA_GITLAB_WRITE_TOKEN=replace-me
# MAMBA_MICROSOFT_GRAPH_TOKEN=replace-me
# MAMBA_GOOGLE_WORKSPACE_TOKEN=replace-me
